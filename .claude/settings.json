{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "mcp__github__create_pull_request"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-branch-not-merged.sh",
            "timeout": 15,
            "statusMessage": "Checking branch is not already merged"
          }
        ]
      }
    ]
  }
}
